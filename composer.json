{
    "name": "h3mantd/iptools",
    "type": "library",
    "description": "PHP Library for manipulating network addresses (IPv4 and IPv6)",
    "keywords": [
        "IP-Tools",
        "network",
        "subnet",
        "cidr",
        "IP",
        "IPv4",
        "IPv6"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "h3mantD",
            "homepage": "https://github.com/h3mantD"
        },
        {
            "name": "Safarov Alisher",
            "email": "alisher.safarov@outlook.com",
            "homepage": "https://github.com/S1lentium"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-bcmath": "*"
    },
    "suggest": {
        "illuminate/console": "Required to use the iptools:install Artisan command",
        "illuminate/database": "Required to use the LaravelRangeStorage adapter and Eloquent model",
        "illuminate/support": "Required for Laravel service provider integration and publishing assets"
    },
    "require-dev": {
        "php-coveralls/php-coveralls": "^2.5",
        "phpunit/phpunit": "^10.5 || ^11.0 || ^12.0",
        "laravel/pint": "^1.27",
        "rector/rector": "^2.3",
        "phpstan/phpstan": "^2.1",
        "illuminate/console": "^11.0 || ^12.0",
        "illuminate/support": "^11.0 || ^12.0",
        "illuminate/database": "^11.0 || ^12.0"
    },
    "autoload": {
        "psr-4": {
            "IPTools\\": "src/"
        },
        "files": [
            "src/compat.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "IPTools\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit --no-coverage",
        "test-coverage": "vendor/bin/phpunit",
        "analyse": "vendor/bin/phpstan analyse -c phpstan.neon.dist",
        "format": "vendor/bin/pint",
        "format-check": "vendor/bin/pint --test",
        "refactor": "vendor/bin/rector process --dry-run"
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "IPTools\\IPToolsServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
